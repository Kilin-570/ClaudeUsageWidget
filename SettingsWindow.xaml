<Window x:Class="ClaudeUsageWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <StackPanel x:Name="Root" Margin="22,18,22,22">

        <TextBlock x:Name="LanguageLabel" Text="語言" FontSize="13" FontWeight="SemiBold"/>
        <ComboBox x:Name="LanguageCombo" Margin="0,6,0,0" Padding="6,5"
                  SelectionChanged="OnLanguageChanged">
            <ComboBoxItem Content="繁體中文"/>
            <ComboBoxItem Content="English"/>
        </ComboBox>

        <TextBlock x:Name="ThemeLabel" Text="主題" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,0"/>
        <ComboBox x:Name="ThemeCombo" Margin="0,6,0,0" Padding="6,5"
                  SelectionChanged="OnThemeChanged">
            <ComboBoxItem Content="深色"/>
            <ComboBoxItem Content="淺色"/>
        </ComboBox>

        <TextBlock x:Name="IntervalLabel" Text="更新頻率" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,0"/>
        <ComboBox x:Name="IntervalCombo" Margin="0,6,0,0" Padding="6,5"
                  SelectionChanged="OnIntervalChanged">
            <ComboBoxItem/>
            <ComboBoxItem/>
            <ComboBoxItem/>
            <ComboBoxItem/>
        </ComboBox>

        <TextBlock x:Name="CodexPathLabel" Text="Codex 執行檔（選填）" FontSize="13"
                   FontWeight="SemiBold" Margin="0,16,0,0"/>
        <DockPanel Margin="0,6,0,0">
            <Button x:Name="CodexBrowseButton" DockPanel.Dock="Right" Content="瀏覽…"
                    Margin="8,0,0,0" Padding="10,5" Click="OnCodexBrowseClick"/>
            <TextBox x:Name="CodexPathBox" Padding="6,5" VerticalContentAlignment="Center"
                     LostFocus="OnCodexPathLostFocus"/>
        </DockPanel>
        <TextBlock x:Name="CodexPathHint" TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"/>

        <DockPanel Margin="0,16,0,0">
            <TextBlock x:Name="OpacityLabel" Text="背景透明度" FontSize="13" FontWeight="SemiBold"/>
            <TextBlock x:Name="OpacityValue" Text="10%" FontSize="13" HorizontalAlignment="Right"/>
        </DockPanel>
        <Slider x:Name="OpacitySlider" Margin="0,8,0,0" Minimum="0" Maximum="100"
                TickFrequency="5" IsSnapToTickEnabled="True"
                ValueChanged="OnOpacityChanged"/>
        <TextBlock x:Name="OpacityHint" Text="" FontSize="11" Margin="0,4,0,0"/>

    </StackPanel>
</Window>
