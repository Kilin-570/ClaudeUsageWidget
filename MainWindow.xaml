<Window x:Class="ClaudeUsageWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Usage"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="OnDragMove">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem x:Name="RefreshMenuItem" Header="立即更新" Click="OnRefreshClick"/>
            <MenuItem x:Name="HideMenuItem" Header="隱藏小工具" Click="OnHideClick"/>
            <Separator/>
            <MenuItem x:Name="SettingsMenuItem" Header="設定…" Click="OnSettingsClick"/>
            <MenuItem x:Name="AutoStartMenuItem" Header="開機自動啟動" IsCheckable="True" Click="OnAutoStartToggle"/>
            <MenuItem x:Name="ReloginMenuItem" Header="重新登入" Click="OnReloginClick"/>
            <Separator/>
            <MenuItem x:Name="ExitMenuItem" Header="結束" Click="OnExitClick"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="RootBorder" CornerRadius="10" Background="#E6191922" Padding="12,10" MinWidth="215">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <DockPanel x:Name="TitleRow" Margin="0,0,0,6">
                <TextBlock x:Name="ToggleGlyph" DockPanel.Dock="Right" Text="▾" Foreground="#FF8A8A96"
                           FontSize="11" Margin="8,0,0,0" Padding="2,0" VerticalAlignment="Center"
                           Cursor="Hand" MouseLeftButtonDown="OnToggleCollapse"/>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="" Foreground="#FF8A8A96"
                           FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TitleText" Text="Claude 用量" Foreground="#FFDDDDE4" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CompactText" FontSize="11" FontWeight="SemiBold" Margin="8,0,8,0"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
            </DockPanel>
            <StackPanel x:Name="RowsPanel"/>
            <TextBlock x:Name="ErrorText" Foreground="#FFFF9E80" FontSize="11"
                       TextWrapping="Wrap" MaxWidth="220" Visibility="Collapsed" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</Window>
