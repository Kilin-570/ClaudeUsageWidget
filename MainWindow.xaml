<Window x:Class="ClaudeUsageWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Usage"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="OnMouseDown" MouseMove="OnMouseMoveWindow"
        MouseLeftButtonUp="OnMouseUpWindow" MouseLeave="OnMouseLeaveWindow">
    <Window.Resources>
        <Style x:Key="ProviderButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem x:Name="RefreshMenuItem" Header="立即更新" Click="OnRefreshClick"/>
            <MenuItem x:Name="HideMenuItem" Header="隱藏小工具" Click="OnHideClick"/>
            <Separator/>
            <MenuItem x:Name="SettingsMenuItem" Header="設定…" Click="OnSettingsClick"/>
            <MenuItem x:Name="AutoStartMenuItem" Header="開機自動啟動" IsCheckable="True" Click="OnAutoStartToggle"/>
            <MenuItem x:Name="CheckUpdateMenuItem" Header="檢查更新" Click="OnCheckUpdateClick"/>
            <MenuItem x:Name="ReloginMenuItem" Header="重新登入" Click="OnReloginClick"/>
            <Separator/>
            <MenuItem x:Name="ExitMenuItem" Header="結束" Click="OnExitClick"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="RootBorder" CornerRadius="10" Background="#E6191922" Padding="12,10" MinWidth="215">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <DockPanel x:Name="TitleRow" Margin="0,0,0,6">
                <TextBlock x:Name="ToggleGlyph" DockPanel.Dock="Right" Text="▾" Foreground="#FF8A8A96"
                           FontSize="11" Margin="8,0,0,0" Padding="2,0" VerticalAlignment="Center"
                           Cursor="Hand" MouseLeftButtonDown="OnToggleCollapse"/>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="" Foreground="#FF8A8A96"
                           FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TitleText" Text="Claude 用量" Foreground="#FFDDDDE4" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CompactText" FontSize="11" FontWeight="SemiBold" Margin="8,0,8,0"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
            </DockPanel>
            <Grid x:Name="ProviderPanel" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ClaudeProviderButton" Grid.Column="0" Content="Claude"
                        Style="{StaticResource ProviderButtonStyle}"
                        Click="OnClaudeProviderClick"/>
                <Button x:Name="ChatGptProviderButton" Grid.Column="2" Content="ChatGPT"
                        Style="{StaticResource ProviderButtonStyle}"
                        Click="OnChatGptProviderClick"/>
            </Grid>
            <StackPanel x:Name="UpdateProgressPanel" Visibility="Collapsed" Margin="0,0,0,5">
                <DockPanel Margin="0,0,0,3">
                    <Button x:Name="CancelUpdateButton" DockPanel.Dock="Right" Padding="5,1"
                            FontSize="9" Content="Cancel" Click="OnCancelUpdateClick"/>
                    <TextBlock x:Name="UpdateProgressText" FontSize="10"
                               Foreground="#FF8A8A96" VerticalAlignment="Center"/>
                </DockPanel>
                <ProgressBar x:Name="UpdateProgressBar" Height="4" Minimum="0" Maximum="100"/>
            </StackPanel>
            <StackPanel x:Name="RowsPanel"/>
            <TextBlock x:Name="ErrorText" Foreground="#FFFF9E80" FontSize="11"
                       TextWrapping="Wrap" MaxWidth="220" Visibility="Collapsed" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</Window>
